@model IEnumerable<maxi_movie_mvc.Models.Pelicula>

@{
    ViewData["Title"] = "Administración de Películas";
}

<div class="container py-4">
    @* Encabezado del Módulo *@
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
        <div>
            <h1 class="fs-2 fw-bold text-light mb-1">Catálogo de Películas</h1>
            <p class="text-muted small mb-0">Gestiona las películas, sus géneros correspondientes y plataformas de streaming disponibles.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary d-inline-flex align-items-center gap-2 px-3 py-2 shadow-sm fw-medium">
            <span class="material-symbols-outlined fs-5">movie</span>
            <span>Nueva Película</span>
        </a>
    </div>

    @* Contenedor de la Tabla Estilizada *@
    <div class="card border-0 shadow bg-dark text-light overflow-hidden">
        <div class="table-responsive p-3">
            <table class="table table-dark table-hover align-middle mb-0" id="tablaPeliculas" style="width:100%">
                <thead class="table-light text-dark fw-bold">
                    <tr>
                        <th style="width: 80px;">Imagen</th>
                        <th>@Html.DisplayNameFor(model => model.Titulo)</th>
                        <th>@Html.DisplayNameFor(model => model.Genero)</th>
                        <th>@Html.DisplayNameFor(model => model.Plataforma)</th>
                        <th class="text-end pe-3" style="width: 140px;">Acciones</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-inline-block bg-secondary bg-opacity-20 rounded p-1 shadow-sm">
                                    @if (!string.IsNullOrEmpty(item.PosterUrlPortada))
                                    {
                                        <img src="@item.PosterUrlPortada" alt="Póster de @item.Titulo" class="rounded" style="height: 60px; width: 42px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center rounded bg-secondary text-light-50 small" style="height: 60px; width: 42px;">
                                            <span class="material-symbols-outlined fs-5">image_not_supported</span>
                                        </div>
                                    }
                                </div>
                            </td>
                            <td class="fw-semibold text-white">
                                @Html.DisplayFor(modelItem => item.Titulo)
                            </td>
                            <td>
                                <span class="badge bg-secondary bg-opacity-20 border border-secondary text-light px-2.5 py-1.5 small rounded-pill">
                                    @Html.DisplayFor(modelItem => item.Genero.Descripcion)
                                </span>
                            </td>
                            <td>
                                <span class="text-info fw-medium">
                                    @Html.DisplayFor(modelItem => item.Plataforma.Nombre)
                                </span>
                            </td>
                            <td>
                                @* Botones de Acción Agrupados con Estilo Icono *@
                                <div class="d-flex justify-content-end gap-1 pe-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning d-inline-flex align-items-center justify-content-center p-2" title="Editar Película">
                                        <span class="material-symbols-outlined fs-5">edit</span>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info d-inline-flex align-items-center justify-content-center p-2" title="Detalles">
                                        <span class="material-symbols-outlined fs-5">info</span>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger d-inline-flex align-items-center justify-content-center p-2" title="Eliminar">
                                        <span class="material-symbols-outlined fs-5">delete</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaPeliculas').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json'
                },
                columnDefs: [
                    { orderable: false, targets: [0, 4] } // Deshabilitar ordenamiento en columnas Imagen y Acciones
                ],
                pageLength: 5,
                lengthMenu: [[5, 10, 25, 50, -1], [5, 10, 25, 50, "Todos"]],
                order: [[1, 'asc']] // Ordenar por Título por defecto
            });
        });
    </script>
}
