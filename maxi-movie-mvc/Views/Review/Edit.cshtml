@model ReviewCreateViewModel

@{
    ViewData["Title"] = "Editar Reseña";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            @* Tarjeta Principal Estilizada *@
            <div class="card border-0 shadow-lg text-white rounded-3" style="background-color: #212529;">

                @* Cabecera de la Tarjeta *@
                <div class="card-header border-secondary border-opacity-25 p-4 bg-transparent">
                    <h2 class="fs-4 fw-bold mb-1 d-flex align-items-center gap-2 text-white">
                        <span class="material-symbols-outlined text-warning fs-3">rate_review</span>
                        <span>Editar Reseña</span>
                    </h2>
                    <p class="text-white-50 small mb-0">Película: <span class="text-primary fw-semibold">@Model.PeliculaTitulo</span></p>
                </div>

                @* Cuerpo del Formulario *@
                <div class="card-body p-4">
                    <form asp-controller="Review" asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="PeliculaId" />

                        @* Sección de Calificación *@
                        <div class="mb-4">
                            <label class="form-label fw-semibold text-white-50 small text-uppercase tracking-wider mb-2">Tu Calificación</label>

                            @* Cambiamos las clases flex para que el truco del CSS ordene del 1 al 5 de izquierda a derecha *@
                            <div class="rating-stars bg-dark p-3 rounded-3 d-flex flex-row-reverse justify-content-center gap-2 shadow-sm" style="border: 1px solid rgba(255,255,255,0.05);">
                                <input type="radio" asp-for="Rating" value="5" id="star5" checked="@(Model.Rating == 5)" />
                                <label for="star5" class="star">★</label>

                                <input type="radio" asp-for="Rating" value="4" id="star4" checked="@(Model.Rating == 4)" />
                                <label for="star4" class="star">★</label>

                                <input type="radio" asp-for="Rating" value="3" id="star3" checked="@(Model.Rating == 3)" />
                                <label for="star3" class="star">★</label>

                                <input type="radio" asp-for="Rating" value="2" id="star2" checked="@(Model.Rating == 2)" />
                                <label for="star2" class="star">★</label>

                                <input type="radio" asp-for="Rating" value="1" id="star1" checked="@(Model.Rating == 1)" />
                                <label for="star1" class="star">★</label>
                            </div>
                            <span asp-validation-for="Rating" class="text-danger small mt-1 d-block"></span>
                        </div>

                        @* Sección de Comentario *@
                        <div class="mb-4">
                            <label asp-for="Comentario" class="form-label fw-semibold text-white-50 small text-uppercase tracking-wider mb-2">Tu Opinión</label>
                            <textarea asp-for="Comentario"
                                      class="form-control text-white border-0 rounded-3 p-3 shadow-sm"
                                      rows="5"
                                      style="background-color: #1a1d20; border: 1px solid rgba(255,255,255,0.05)!important; resize: none;"
                                      placeholder="Comparte tu opinión sobre esta película...">@Model.Comentario</textarea>
                            <span asp-validation-for="Comentario" class="text-danger small mt-1 d-block"></span>
                        </div>

                        @* Acciones *@
                        <div class="d-flex align-items-center gap-2 pt-2 border-top border-secondary border-opacity-10">
                            <button type="submit" class="btn btn-primary px-4 py-2 rounded-3 fw-semibold shadow-sm d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined fs-5">save</span>
                                <span>Guardar Cambios</span>
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-3 fw-semibold border-secondary border-opacity-50">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>

            </div>

        </div>
    </div>
</div>

@* 🔥 El CSS definitivo para tunear las estrellas perfectamente *@
<style>
    .rating-stars input[type="radio"] {
        display: none; /* Oculta los círculos nativos feos */
    }

    .rating-stars .star {
        font-size: 2rem;
        color: #4a4f55; /* Color gris apagado por defecto para estrellas vacías */
        cursor: pointer;
        transition: color 0.15s ease-in-out;
    }

        /* Ilumina las estrellas seleccionadas y sus predecesoras */
        .rating-stars input[type="radio"]:checked ~ .star,
        .rating-stars .star:hover,
        .rating-stars .star:hover ~ .star {
            color: #ffc107 !important; /* Dorado cinematográfico */
        }
</style>