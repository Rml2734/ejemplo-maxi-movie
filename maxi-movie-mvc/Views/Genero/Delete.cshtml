@model maxi_movie_mvc.Models.Genero

@{
    ViewData["Title"] = "Eliminar Género";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            @* Tarjeta de Confirmación de Eliminación *@
            <div class="card border-0 shadow bg-dark text-light">
                <div class="card-body p-4">

                    @* Encabezado interno con Alerta *@
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="material-symbols-outlined text-danger fs-3">warning</span>
                        <h2 class="fs-4 fw-bold mb-0 text-danger">¿Eliminar Género?</h2>
                    </div>

                    <p class="text-muted small mb-4">Esta acción no se puede deshacer. Por favor confirma si deseas borrar el siguiente registro:</p>

                    @* Contenedor del Dato a borrar *@
                    <div class="bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded p-3 mb-4">
                        <div class="small text-danger text-opacity-75 fw-medium mb-1">
                            @Html.DisplayNameFor(model => model.Descripcion)
                        </div>
                        <div class="fs-5 fw-semibold text-light">
                            @Html.DisplayFor(model => model.Descripcion)
                        </div>
                    </div>

                    @* Formulario y Botones de Acción *@
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex align-items-center justify-content-between pt-2">
                            <a asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2">
                                <span class="material-symbols-outlined fs-5">arrow_back</span>
                                <span>Regresar</span>
                            </a>
                            <button type="submit" class="btn btn-danger d-inline-flex align-items-center gap-2 px-4">
                                <span class="material-symbols-outlined fs-5">delete_forever</span>
                                <span>Confirmar Eliminar</span>
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>