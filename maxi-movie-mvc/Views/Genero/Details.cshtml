@model maxi_movie_mvc.Models.Genero

@{
    ViewData["Title"] = "Detalles del Género";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            @* Tarjeta de Detalles *@
            <div class="card border-0 shadow bg-dark text-light">
                <div class="card-body p-4">

                    @* Encabezado interno *@
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <span class="material-symbols-outlined text-info fs-3">info</span>
                        <h2 class="fs-4 fw-bold mb-0">Detalles del Género</h2>
                    </div>

                    @* Contenedor de Información *@
                    <div class="bg-secondary bg-opacity-10 border border-secondary border-opacity-25 rounded p-3 mb-4">
                        <div class="small text-muted fw-medium mb-1">
                            @Html.DisplayNameFor(model => model.Descripcion)
                        </div>
                        <div class="fs-5 fw-semibold text-light">
                            @Html.DisplayFor(model => model.Descripcion)
                        </div>
                    </div>

                    @* Botones de Acción *@
                    <div class="d-flex align-items-center justify-content-between pt-2">
                        <a asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-5">arrow_back</span>
                            <span>Regresar</span>
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-info d-inline-flex align-items-center gap-2 px-4 text-dark fw-medium">
                            <span class="material-symbols-outlined fs-5">edit</span>
                            <span>Editar</span>
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>