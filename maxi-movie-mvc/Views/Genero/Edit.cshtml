@model maxi_movie_mvc.Models.Genero

@{
    ViewData["Title"] = "Editar Género";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            @* Tarjeta del Formulario *@
            <div class="card border-0 shadow bg-dark text-light">
                <div class="card-body p-4">

                    @* Encabezado interno *@
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <span class="material-symbols-outlined text-warning fs-3">edit</span>
                        <h2 class="fs-4 fw-bold mb-0">Modificar Género</h2>
                    </div>

                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        @* El ID oculto que EF necesita *@
                        <input type="hidden" asp-for="Id" />

                        @* Campo de Descripción *@
                        <div class="mb-4">
                            <label asp-for="Descripcion" class="form-label text-muted small fw-medium mb-2">Nombre del Género</label>
                            <input asp-for="Descripcion" class="form-control bg-secondary bg-opacity-10 border-secondary text-light py-2" placeholder="Ej: Acción, Drama..." />
                            <span asp-validation-for="Descripcion" class="text-danger small mt-1 d-block"></span>
                        </div>

                        @* Botones de Acción *@
                        <div class="d-flex align-items-center justify-content-between pt-2">
                            <a asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2">
                                <span class="material-symbols-outlined fs-5">arrow_back</span>
                                <span>Regresar</span>
                            </a>
                            <button type="submit" class="btn btn-warning d-inline-flex align-items-center gap-2 px-4 text-dark fw-medium">
                                <span class="material-symbols-outlined fs-5">save</span>
                                <span>Guardar Cambios</span>
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}