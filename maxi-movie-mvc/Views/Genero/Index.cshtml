@model IEnumerable<maxi_movie_mvc.Models.Genero>

@{
    ViewData["Title"] = "Administrar Géneros";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fs-3 fw-bold text-light mb-1">Administración de Géneros</h1>
            <p class="text-muted small mb-0">Gestiona las categorías disponibles para clasificar las películas.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm">
            <span class="material-symbols-outlined fs-5">add_circle</span>
            <span>Nuevo Género</span>
        </a>
    </div>

    <div class="card border-0 shadow-sm bg-dark text-light overflow-hidden">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead class="table-light text-dark">
                    <tr>
                        <th class="py-3 px-4" style="width: 70%;">
                            @Html.DisplayNameFor(model => model.Descripcion)
                        </th>
                        <th class="py-3 px-4 text-end" style="width: 30%;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="py-3 px-4 fw-medium">
                                @Html.DisplayFor(modelItem => item.Descripcion)
                            </td>
                            <td class="py-3 px-4 text-end">
                                <div class="btn-group gap-2" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning d-inline-flex align-items-center justify-content-center p-2" title="Editar">
                                        <span class="material-symbols-outlined fs-5">edit</span>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info d-inline-flex align-items-center justify-content-center p-2" title="Detalles">
                                        <span class="material-symbols-outlined fs-5">info</span>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger d-inline-flex align-items-center justify-content-center p-2" title="Eliminar">
                                        <span class="material-symbols-outlined fs-5">delete</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>