@model maxi_movie_mvc.Models.Plataforma

@{
    ViewData["Title"] = "Eliminar Plataforma";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            @* Tarjeta de Alerta *@
            <div class="card border-0 shadow bg-dark text-light">
                <div class="card-body p-4">

                    @* Encabezado de Advertencia *@
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="material-symbols-outlined text-danger fs-3">warning</span>
                        <h2 class="fs-4 fw-bold mb-0 text-danger">¿Eliminar Plataforma?</h2>
                    </div>

                    <p class="text-muted small mb-4">Esta acción no se puede revertir. Confirma si realmente deseas borrar la siguiente plataforma del sistema:</p>

                    @* Ficha del Registro a borrar *@
                    <div class="bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded p-3 mb-4">
                        <div class="row align-items-center g-3">

                            @* Miniatura del Logo *@
                            <div class="col-sm-3 text-center">
                                <div class="bg-light p-2 rounded d-inline-block">
                                    @if (!string.IsNullOrEmpty(Model?.LogoUrl))
                                    {
                                        <img src="@Model.LogoUrl" alt="Logo @Model.Nombre" class="img-fluid" style="max-height: 60px; object-fit: contain;" />
                                    }
                                    else
                                    {
                                        <span class="text-dark small fw-bold">Sin Logo</span>
                                    }
                                </div>
                            </div>

                            @* Datos de la Plataforma *@
                            <div class="col-sm-9">
                                <div class="mb-2">
                                    <span class="text-danger text-opacity-75 small d-block fw-medium">Nombre de la plataforma</span>
                                    <span class="fs-5 fw-bold text-white">@Html.DisplayFor(model => model.Nombre)</span>
                                </div>
                                <div class="mb-0">
                                    <span class="text-danger text-opacity-75 small d-block fw-medium">Sitio Web</span>
                                    <span class="text-white-50 small text-break font-monospace">@Html.DisplayFor(model => model.Url)</span>
                                </div>
                            </div>

                        </div>
                    </div>

                    @* Formulario de Confirmación *@
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex align-items-center justify-content-between pt-2">
                            <a asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2">
                                <span class="material-symbols-outlined fs-5">arrow_back</span>
                                <span>Regresar</span>
                            </a>
                            <button type="submit" class="btn btn-danger d-inline-flex align-items-center gap-2 px-4">
                                <span class="material-symbols-outlined fs-5">delete_forever</span>
                                <span>Confirmar Eliminar</span>
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>