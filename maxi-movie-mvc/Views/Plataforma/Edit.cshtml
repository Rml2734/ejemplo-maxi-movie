@model maxi_movie_mvc.Models.Plataforma

@{
    ViewData["Title"] = "Editar Plataforma";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">

            @* Tarjeta del Formulario de Edición *@
            <div class="card border-0 shadow bg-dark text-light">
                <div class="card-body p-4">

                    @* Encabezado interno *@
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <span class="material-symbols-outlined text-warning fs-3">edit</span>
                        <h2 class="fs-4 fw-bold mb-0">Editar Plataforma</h2>
                    </div>

                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        @* ID Oculto necesario para el POST *@
                        <input type="hidden" asp-for="Id" />

                        @* Campo: Nombre *@
                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label text-muted small fw-medium mb-1">Nombre de la Plataforma</label>
                            <input asp-for="Nombre" class="form-control bg-secondary bg-opacity-10 border-secondary text-light py-2" placeholder="Ej: Netflix, Prime Video..." />
                            <span asp-validation-for="Nombre" class="text-danger small mt-1 d-block"></span>
                        </div>

                        @* Campo: Sitio Web (URL) *@
                        <div class="mb-3">
                            <label asp-for="Url" class="form-label text-muted small fw-medium mb-1">Enlace del Sitio Web</label>
                            <input asp-for="Url" class="form-control bg-secondary bg-opacity-10 border-secondary text-light py-2" placeholder="https://www.ejemplo.com" />
                            <span asp-validation-for="Url" class="text-danger small mt-1 d-block"></span>
                        </div>

                        @* Campo: Logo Url *@
                        <div class="mb-4">
                            <label asp-for="LogoUrl" class="form-label text-muted small fw-medium mb-1">Dirección URL del Logo</label>
                            <input asp-for="LogoUrl" class="form-control bg-secondary bg-opacity-10 border-secondary text-light py-2" placeholder="Pega el enlace de la imagen aquí..." />
                            <span asp-validation-for="LogoUrl" class="text-danger small mt-1 d-block"></span>
                        </div>

                        @* Botones de Acción *@
                        <div class="d-flex align-items-center justify-content-between pt-2">
                            <a asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2">
                                <span class="material-symbols-outlined fs-5">arrow_back</span>
                                <span>Regresar</span>
                            </a>
                            <button type="submit" class="btn btn-warning d-inline-flex align-items-center gap-2 px-4 text-dark fw-medium">
                                <span class="material-symbols-outlined fs-5">save</span>
                                <span>Guardar Cambios</span>
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}