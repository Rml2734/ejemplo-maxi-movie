@model List<Pelicula>
@{
    ViewData["Title"] = "Home Page";
    var paginaActual = ViewBag.PaginaActual ?? 1;
    var totalPaginas = ViewBag.TotalPaginas ?? 1;
    var totalPeliculas = ViewBag.TotalPeliculas ?? 0;
    var busqueda = ViewBag.TxtBusqueda ?? "";
    var generoId = ViewBag.GeneroId ?? 0;
    // Nueva variable para controlar el estado de la grilla/lista
    var vista = ViewBag.Vista ?? "grid";
}

<main class="flex-grow-1">
    <div class="container py-4">
        @* panel de filtros *@
        <form method="get">
            <div class="row g-3 mb-4 align-items-center">
                <div class="col-lg-6">
                    <div class="input-group">
                        <button type="submit" class="input-group-text">Buscar</button>
                        <input name="txtBusqueda" value="@busqueda" class="form-control form-control-lg" placeholder="Buscar películas..." type="text" />
                    </div>
                </div>
                <div class="col-lg-6 d-flex flex-wrap gap-2 justify-content-lg-end">
                    <div class="dropdown">
                        <select name="generoId" asp-items="@ViewBag.GeneroId" class="form-select form-select-lg btn-outline-secondary"
                                onchange="this.form.submit()"></select>
                    </div>

                    @* Botones de vista convertidos en enlaces dinámicos *@
                    <div class="btn-group" role="group">
                        <a asp-action="Index"
                           asp-route-txtBusqueda="@busqueda"
                           asp-route-generoId="@generoId"
                           asp-route-vista="grid"
                           class="btn @(vista == "grid" ? "btn-primary" : "btn-outline-secondary")">
                            <span class="material-symbols-outlined align-middle">grid_view</span>
                        </a>

                        <a asp-action="Index"
                           asp-route-txtBusqueda="@busqueda"
                           asp-route-generoId="@generoId"
                           asp-route-vista="list"
                           class="btn @(vista == "list" ? "btn-primary" : "btn-outline-secondary")">
                            <span class="material-symbols-outlined align-middle">view_list</span>
                        </a>
                    </div>
                </div>
            </div>
            @* Mantenemos oculto el estado de la vista para que al buscar o filtrar no se pierda *@
            <input type="hidden" name="vista" value="@vista" />
        </form>

        @* listado condicional según la vista seleccionada *@
        @if (vista == "list")
        {
            <div class="row g-3">
                @foreach (var pelicula in Model)
                {
                    <div class="col-12">
                        <a asp-action="Details" asp-route-id="@pelicula.Id" class="text-decoration-none">
                            <div class="card shadow-sm border-0 h-100">
                                <div class="d-flex align-items-center">
                                    <img alt="@pelicula.Titulo" src="@pelicula.PosterUrlPortada" style="width: 90px; height: 130px; object-fit: cover; border-top-left-radius: var(--bs-card-inner-border-radius); border-bottom-left-radius: var(--bs-card-inner-border-radius);" />
                                    <div class="card-body p-3">
                                        <h5 class="card-title fs-5 fw-semibold mb-1 text-dark">@pelicula.Titulo</h5>
                                        <div class="d-flex align-items-center text-muted small">
                                            <span class="material-symbols-outlined text-warning me-1" style="font-size: 1rem;"> star </span>
                                            <span>4.5</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-4">
                @foreach (var pelicula in Model)
                {
                    <div class="col">
                        <a asp-action="Details" asp-route-id="@pelicula.Id">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="position-relative">
                                    <img alt="@pelicula.Titulo" class="card-img-top" src="@pelicula.PosterUrlPortada" />
                                </div>
                                <div class="card-body p-2">
                                    <h5 class="card-title fs-6 fw-semibold mb-1">@pelicula.Titulo</h5>
                                    <div class="d-flex align-items-center text-muted small">
                                        <span class="material-symbols-outlined text-warning me-1" style="font-size: 1rem;"> star </span>
                                        <span>4.5</span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }

        @if (totalPaginas > 1)
        {
            <div class="row mt-4">
                <div class="col-12">
                    <nav aria-label="Navegación de páginas">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                <a asp-action="Index" class="page-link" asp-route-pagina="@(paginaActual - 1)" asp-route-txtBusqueda="@busqueda" asp-route-generoId="@generoId" asp-route-vista="@vista">Anterior</a>
                            </li>

                            @for (int i = 1; i <= totalPaginas; i++)
                            {
                                <li class="page-item @(i == paginaActual ? "active" : "")">
                                    <a asp-action="Index" asp-route-pagina="@i" class="page-link" asp-route-txtBusqueda="@busqueda" asp-route-generoId="@generoId" asp-route-vista="@vista">@i</a>
                                </li>
                            }

                            <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                <a asp-action="Index" class="page-link" asp-route-pagina="@(paginaActual + 1)" asp-route-txtBusqueda="@busqueda" asp-route-generoId="@generoId" asp-route-vista="@vista">Siguiente</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        }
    </div>
</main>