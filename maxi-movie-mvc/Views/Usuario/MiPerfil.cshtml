@model MiPerfilViewModel

@{
    ViewData["Title"] = "Mi Perfil";
    string mensaje = ViewData["Mensaje"] as string ?? "";
}

<style>
    /* Estilos específicos y refinados para el contenedor de la foto de perfil */
    .profile-img-container {
        position: relative;
        width: 128px;
        height: 128px;
        margin: 0 auto;
    }

    .profile-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
        border: 4px solid rgba(17, 147, 212, 0.4);
    }

    .edit-btn {
        position: absolute;
        bottom: 0;
        right: 0;
        background-color: #1193d4;
        color: white;
        border: none;
        border-radius: 50%;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease-in-out;
    }

        .edit-btn:hover {
            transform: scale(1.1);
            background-color: #0f84bf;
        }
</style>

<main class="flex-grow-1 d-flex align-items-center justify-content-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6 col-xl-5">

                @* Mensaje de éxito al guardar cambios *@
                @if (!string.IsNullOrEmpty(mensaje))
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 mb-4 shadow-sm" role="alert">
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-5">check_circle</span>
                            <span>@mensaje</span>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @* Tarjeta de Perfil *@
                <div class="card bg-dark text-light p-4 p-md-5 border border-secondary border-opacity-25 shadow-lg rounded-3">
                    <form method="post" enctype="multipart/form-data" novalidate>

                        @* Sección Superior: Avatar y Encabezado *@
                        <div class="text-center mb-4">
                            <div class="profile-img-container mb-3">
                                <img alt="Foto de perfil" id="profileImage" class="profile-img shadow" src="@Model.ImagenUrlPerfil" />
                                <button type="button" class="edit-btn shadow" onclick="document.getElementById('inputImagenPerfil').click()">
                                    <span class="material-symbols-outlined fs-6">edit</span>
                                </button>
                                @* Forzamos el ID exacto para que el JavaScript y el botón funcionen al 100% *@
                                <input type="file" asp-for="ImagenPerfil" id="inputImagenPerfil" accept="image/png,image/jpeg,image/webp" class="d-none" onchange="previewImage(this)" />
                            </div>
                            <h2 class="fs-3 fw-bold mb-1 text-white">@Model.Nombre @Model.Apellido</h2>
                            <p class="text-white-50 small mb-0 font-monospace">@Model.Email</p>
                        </div>

                        @* Formulario de Datos *@
                        <div class="mb-3">
                            <label class="form-label text-light small fw-bold" asp-for="Nombre">Nombre</label>
                            <input asp-for="Nombre" class="form-control form-control-lg text-white bg-dark border-secondary" placeholder="Ingresa tu nombre" />
                            <span asp-validation-for="Nombre" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-light small fw-bold" asp-for="Apellido">Apellido</label>
                            <input asp-for="Apellido" class="form-control form-control-lg text-white bg-dark border-secondary" placeholder="Ingresa tu apellido" />
                            <span asp-validation-for="Apellido" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-light small fw-bold" asp-for="Email">Correo electrónico</label>
                            <input asp-for="Email" class="form-control form-control-lg text-white-50 bg-secondary bg-opacity-10 border-secondary" disabled placeholder="tu.correo@email.com" />
                        </div>

                        <button class="btn btn-primary btn-lg w-100 fw-bold shadow-sm" type="submit">
                            Guardar cambios
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>
</main>

<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('profileImage').src = e.target.result;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>