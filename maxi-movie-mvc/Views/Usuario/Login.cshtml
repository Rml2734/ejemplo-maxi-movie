@model LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
}

<main class="flex-grow-1 d-flex align-items-center justify-content-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5 col-xl-4">
                <div class="card shadow-lg border-0 rounded-3">
                    <div class="card-body p-4 p-sm-5">
                        <h2 class="card-title text-center mb-4 h3">Iniciar sesión</h2>
                        <form method="post" novalidate>
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label text-light small fw-bold">Correo electrónico</label>
                                <input asp-for="Email" class="form-control form-control-lg text-white bg-dark border-secondary" placeholder="ejemplo@correo.com" />
                                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Clave" class="form-label text-light small fw-bold">Contraseña</label>
                                <input asp-for="Clave" type="password" class="form-control form-control-lg text-white bg-dark border-secondary" placeholder="Ingresa tu contraseña" />
                                <span asp-validation-for="Clave" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check d-flex align-items-center m-0">
                                    <input class="form-check-input m-0" asp-for="Recordarme" />
                                    <label class="form-check-label text-light small ms-2" asp-for="Recordarme">Recordarme</label>
                                </div>
                                <a class="text-info small text-decoration-none" href="#">¿Olvidaste tu contraseña?</a>
                            </div>

                            <div class="d-grid">
                                <button class="btn btn-primary btn-lg" type="submit">Iniciar sesión</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
